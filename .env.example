# ─── App ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Auth ─────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here
ENCRYPTION_KEY=your_encryption_key_here

# ─── Stripe ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Resend (Email) ───────────────────────────────────────────────
# Get from https://resend.com/api-keys
RESEND_API_KEY=re_...
# From address — must be a verified domain in Resend (free tier: onboarding@resend.dev)
RESEND_FROM_EMAIL=ClientPulse <hello@yourdomain.com>

# ─── Cron Security ────────────────────────────────────────────────
# Generate: openssl rand -hex 32 — set same value in Vercel env vars
CRON_SECRET=your_cron_secret_here

# ─── Alerts ───────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALERT_USER_ID=
